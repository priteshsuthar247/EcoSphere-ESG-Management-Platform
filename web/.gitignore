# =====================================================
# EcoSphere ESG Platform — .gitignore
# =====================================================

# ── Dependencies ──────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────
.next/
out/
build/

# ── Environment & Secrets ─────────────────────────
# NEVER commit secrets or local env files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ── Database ──────────────────────────────────────
# SQL files that may contain seed passwords go here
# (setup_db.sql is safe to commit — no raw passwords, only hashes)
*.sql.bak
*.sql.tmp
db_dump_*.sql
dump_*.sql

# ── Logs ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── Testing & Coverage ────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov

# ── TypeScript ────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors & IDEs ────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── Certificates & Keys ───────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Uploads & User Files ──────────────────────────
public/uploads/
uploads/

# ── Misc ──────────────────────────────────────────
.vercel
.turbo
*.tgz
.cache/
